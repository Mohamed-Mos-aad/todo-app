generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}


model User { 
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  email           String  @unique
  name            String?
  profile_img     String
  createdAt       DateTime
  Tasks           Task[]
} 

model Task { 
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  completed       Boolean
  createdAt       DateTime
  userId          String  @db.ObjectId
  user            User    @relation(fields: [userId], references: [id])
}